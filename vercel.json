{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "flask",
  "regions": ["sin1"],
  "functions": {
    "app.py": {
      "maxDuration": 30,
      "includeFiles": "portfolio/**/*"
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ]
}